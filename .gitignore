Icon
.DS_Store

# Temporary files
# ---------------

/media/*
!/media/index.html
/docs/*

# Lock files
# ---------------

.lock

# Panel draft scratch space
# -------------------------
# Kirby writes unsaved panel edits into a `_changes/` folder
# next to the content file. These are transient and should
# never be committed.
_changes/

